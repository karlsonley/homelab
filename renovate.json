{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":gitSignOff",
    ":timezone(UTC)",
    "helpers:pinGitHubActionDigests"
  ],
  "description": "Phase 1 + 2: all apps + infra image tags and infrastructure HelmRelease chart versions. Terraform providers (Phase 3) are deferred.",
  "enabledManagers": ["kubernetes", "flux", "github-actions"],
  "kubernetes": {
    "managerFilePatterns": [
      "/^apps/homelab/.+\\.yaml$/",
      "/^infrastructure/homelab/.+\\.yaml$/"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/^infrastructure/homelab/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^infrastructure/homelab/.+\\.yaml$/",
        "/^apps/homelab/.+\\.yaml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s*(?:tag|version):\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?",
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s*image:\\s*\\S+?:(?<currentValue>[^\"'\\s]+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver{{/if}}"
    }
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dependency Dashboard",
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "prCreation": "immediate",
  "rebaseWhen": "behind-base-branch",
  "labels": ["dependencies", "renovate"],
  "commitMessagePrefix": "chore(deps):",
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "packageRules": [
    {
      "description": "Group Immich components into a single PR",
      "matchPackagePatterns": ["immich"],
      "groupName": "immich"
    },
    {
      "description": "ghcr.io images don't embed org.opencontainers.image.created, so Renovate can't evaluate minimumReleaseAge — disable the check to unblock PR creation",
      "matchManagers": ["kubernetes"],
      "minimumReleaseAge": null
    },
    {
      "description": "Patch: eligible for auto-merge once Claude gate applies the automerge-approved label",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "addLabels": ["update-patch"]
    },
    {
      "description": "Minor: require approval",
      "matchUpdateTypes": ["minor"],
      "addLabels": ["update-minor"],
      "automerge": false
    },
    {
      "description": "Major: dashboard-only, tick to create PR",
      "matchUpdateTypes": ["major"],
      "addLabels": ["update-major"],
      "dependencyDashboardApproval": true,
      "automerge": false
    },
    {
      "description": "Pre-1.0 packages: treat minor as major (Glance is currently v0.8.x)",
      "matchCurrentVersion": "/^v?0\\./",
      "matchUpdateTypes": ["minor"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "minimumReleaseAge": null,
    "schedule": ["at any time"]
  },
  "osvVulnerabilityAlerts": true
}
